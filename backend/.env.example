# Copy this file to .env and fill in real values
APP_NAME=Recrutify
APP_ENV=development
DEBUG=true

# SQLite for local dev; switch to a Postgres URL in production
DATABASE_URL=sqlite:///./recrutify.db
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/recrutify

# JWT — generate a strong random string for production
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
